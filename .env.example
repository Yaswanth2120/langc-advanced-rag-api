OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=multi-agent-research

SUPABASE_URL=your_supabase_project_url
# Service-role key: what the BACKEND uses to access the documents table
# (bypasses RLS; server-side only — never expose client-side, never log).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Anon/publishable key: NOT used for table access (RLS grants it nothing).
# Optional; only consulted by /supabase/health as a config check.
SUPABASE_KEY=your_supabase_anon_key

# API auth: when set, all /documents/* and /query/* routes require this value
# in an X-API-Key header. Leave unset to disable auth (e.g. local dev).
API_KEY=your_api_key

# Per-IP rate limit for /ask and /query/documents (slowapi syntax).
RATE_LIMIT=30/minute

RAG_CHUNK_SIZE=650
RAG_CHUNK_OVERLAP=80
RAG_TOP_K=4
# Minimum similarity relevance score for a retrieved chunk to be used.
RAG_RELEVANCE_THRESHOLD=0.1
